{
  "name": "ts-automation-app",
  "productName": "TMS Pulse",
  "version": "1.0.1",
  "description": "Internal automation tool for Technical Specialists",
  "main": "dist/main.js",
  "author": "marion jay m balugo",
  "license": "ISC",
  "scripts": {
    "build:js": "node esbuild.config.js",
    "start": "npm run build:js && electron .",
    "build": "npm run build:js && electron-builder --win"
  },
  "imports": {
    "#src/*": "./src/*",
    "#cnf/*": "./src/backend/cnf/*",
    "#svc/*": "./src/backend/svc/*",
    "#utils/*": "./src/backend/utils/*"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "bootstrap": "^5.3.8",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "build": {
    "appId": "com.tsautomation.tmspulse",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "dist/resources/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "dist/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TMS Pulse",
      "uninstallDisplayName": "TMS Pulse"
    }
  }
}
