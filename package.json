{
  "name": "ts-automation-app",
  "productName": "TMS Pulse",
  "version": "1.0.1",
  "description": "Internal automation tool for Technical Specialists",
  "main": "dist/main.js",
  "author": "marion jay m balugo",
  "license": "ISC",
  "scripts": {
    "build:js": "node esbuild.config.js",
    "start": "npm run build:js && electron .",
    "build": "npm run build:js && electron-builder --win",
    "prepare": "husky && node ./node_modules/@balugoorg/git-convention/setup.js"
  },
  "imports": {
    "#src/*": "./src/*",
    "#cnf/*": "./src/backend/cnf/*",
    "#cnf": "./src/backend/cnf/index.js",
    "#svc/*": "./src/backend/svc/*",
    "#svc": "./src/backend/svc/index.js",
    "#utils/*": "./src/backend/utils/*",
    "#utils": "./src/backend/utils/index.js"
  },
  "devDependencies": {
    "@balugoorg/git-convention": "github:balugoOrg/git-convention#release/v1.0.8",
    "@electron/fuses": "^1.8.0",
    "bootstrap": "^5.3.8",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "husky": "^9.1.7",
    "electron-store": "^8.2.0"
  },
  "dependencies": {
  },
  "build": {
    "appId": "com.tsautomation.tmspulse",
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "dist/resources/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "dist/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TMS Pulse",
      "uninstallDisplayName": "TMS Pulse"
    }
  }
}
