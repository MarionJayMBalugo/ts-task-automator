{
  "name": "ts-automation-app",
  "productName": "TMS Pulse",
  "version": "1.0.0",
  "description": "Internal automation tool for Technical Specialists",
  "main": "src/main.js",
  "author": "marion jay m balugo",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "build": {
    "appId": "com.tsautomation.tmspulse",
    "asarUnpack": [
      "resources/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TMS Pulse",
      "uninstallDisplayName": "TMS Pulse"
    }
  }
}
